# ==============================================
# Clipping MCP Server 환경변수 (로컬 개발 기준)
# 이 파일을 .env로 복사한 뒤 값을 채워 사용한다.
# 프로덕션 배포 체크리스트는 docs/DEPLOY_GUIDE.md 참고.
# ==============================================

# === 필수 (서버 시작 시 반드시 필요) =====================================

# 데이터베이스 접속 (기본값 없음 — 미설정 시 서버 기동 실패)
DB_PASSWORD=
DB_URL=jdbc:postgresql://localhost:5434/clipping
DB_USERNAME=clipping_admin

# 로컬 시드/편의 설정
# ⚠️ DEV_BOOTSTRAP=true는 local-bootstrap.sql을 실행하며 clipping_user_requests,
#    user_delivery_schedules 등 유저 데이터 테이블을 DELETE 한다.
#    실 사용자 데이터가 있는 DB에서는 반드시 false. 필요할 때만 임시로 true 후 작업 종료 시 원복.
#    LocalDevBootstrapConfig의 pre-flight guard 가 실 사용자 row 감지 시 abort 하지만 규칙 우선.
#    상세: AGENTS.md §9.1.1, LESSONS.md L-010
DEV_BOOTSTRAP=false                         # fresh seed 필요할 때만 true. 실 데이터 DB 에서는 절대 금지.
MAX_LOGIN_ATTEMPTS_PER_MINUTE=300           # E2E 전체 스위트 통과를 위해 개발에선 상향

# === 권장 (연동 기능 사용 시) ============================================

# AI 요약
GEMINI_API_KEY=

# Slack 발송
SLACK_BOT_TOKEN=                            # xoxb- 로 시작하는 봇 토큰
SLACK_APP_LEVEL_TOKEN=                      # xapp- Socket Mode 앱 토큰 (피드백/공유 버튼용)
SLACK_SOCKET_MODE_ENABLED=false
SLACK_AUTO_DIGEST_ENABLED=false
SLACK_CHANNEL=                              # 기본 발송 채널 ID
SLACK_DAILY_CHANNEL_MESSAGE_LIMIT=50

# 관리자 Bearer 토큰 (외부 스크립트/MCP 테스트용)
# 생성: openssl rand -hex 32
ADMIN_API_TOKEN=

# === MCP 서버 (외부 LLM 연동 시) =========================================

CLIPPING_MCP_SERVER_ENABLED=false           # true 시 /sse + /mcp/message 엔드포인트 활성화
CLIPPING_MCP_SERVICE_TOKEN=                 # MCP Bearer 토큰 (최소 32자). 생성: openssl rand -base64 32

# === 보조 수집 소스 ======================================================

# Naver News API
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# DART (기업 공시)
DART_API_KEY=

# === 인프라 ==============================================================

# Redis (MCP rate limiter 슬라이딩 윈도우)
REDIS_HOST=localhost
REDIS_PORT=6379

# CORS (로컬 프론트 포트 허용)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# === LLM 비용 추적 =======================================================

LLM_INPUT_COST_PER_MILLION_USD=1.25
LLM_OUTPUT_COST_PER_MILLION_USD=5.0

# === 회원가입 정책 =======================================================

ADMIN_ALLOW_SIGNUP=true
USER_ALLOW_SIGNUP=true
ADMIN_ALLOW_BOOTSTRAP_SIGNUP=true

# === OpenAPI =============================================================

SWAGGER_UI_ENABLED=true                     # 프로덕션에선 false 권장 (API 스키마 노출 방지)

# === 프론트 Sentry (Vite build-time, frontend/.env.local 권장) ===========
# VITE_SENTRY_DSN=
# VITE_SENTRY_ENVIRONMENT=development
# VITE_SENTRY_RELEASE=
# VITE_SENTRY_TRACES_SAMPLE_RATE=0

# ==============================================
# === 프로덕션 전용 (로컬에선 비워 둬도 됨) ================================
# ==============================================
# ENCRYPTION_KEY=              # AES-256 Base64. 생성: openssl rand -base64 32. 미설정 시 Slack 토큰 평문 저장
# SLACK_SIGNING_SECRET=        # Slack webhook HMAC 서명 검증. 미설정 시 위조 요청 수용
# SESSION_COOKIE_SECURE=true   # HTTPS 환경 필수
